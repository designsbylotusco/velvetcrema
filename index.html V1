<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Velvet Crema | Cozy Toronto Coffee Shop</title>
  <meta name="description" content="A cozy Toronto coffee spot for coffee, calm, and good taste. Visit Velvet Crema at 1 Yonge Street for beautiful coffee, warm atmosphere, and affordable prices." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f5f0e8;
      --cream-dark: #ede5d5;
      --espresso: #1c1008;
      --espresso-mid: #2e1d0e;
      --brown: #6b4226;
      --amber: #c8832a;
      --amber-light: #e8a94a;
      --text: #1c1008;
      --text-muted: #7a6a58;
      --card: #ffffff;
      --border: #e0d5c5;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: var(--brown); border-radius: 3px; }

    /* ─── NAV ─── */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      transition: all 0.5s ease;
      padding: 1.5rem 0;
    }
    header.scrolled {
      background: rgba(245,240,232,0.97);
      backdrop-filter: blur(12px);
      padding: 1rem 0;
      box-shadow: 0 1px 0 var(--border);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto;
      padding: 0 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-family: var(--serif);
      font-size: 1.75rem; font-weight: 400;
      color: var(--text); text-decoration: none;
      letter-spacing: -0.02em;
    }
    .nav-links { display: flex; align-items: center; gap: 2.5rem; }
    .nav-links a {
      font-family: var(--sans); font-size: 0.8rem;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text-muted); text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-btn {
      font-family: var(--sans); font-size: 0.8rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      border: 1px solid var(--brown);
      background: transparent; color: var(--brown);
      padding: 0.55rem 1.4rem; border-radius: 999px;
      cursor: pointer; transition: all 0.3s;
      text-decoration: none;
    }
    .nav-btn:hover { background: var(--brown); color: var(--cream); }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; background: none; border: none; padding: 4px;
    }
    .hamburger span {
      display: block; width: 24px; height: 1.5px;
      background: var(--text); transition: all 0.3s;
    }
    .mobile-nav {
      display: none; flex-direction: column;
      background: rgba(245,240,232,0.98);
      backdrop-filter: blur(12px);
      padding: 1.5rem 2rem 2rem;
      border-top: 1px solid var(--border);
      gap: 1rem;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      font-family: var(--serif); font-size: 1.5rem;
      color: var(--text); text-decoration: none;
      padding: 0.4rem 0;
    }

    /* ─── HERO ─── */
    #hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1600&q=80');
      background-size: cover; background-position: center;
      transform-origin: center;
      will-change: transform;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom,
        rgba(28,16,8,0.35) 0%,
        rgba(28,16,8,0.15) 40%,
        rgba(28,16,8,0.6) 100%);
    }
    .hero-content {
      position: relative; z-index: 2;
      text-align: center; padding: 0 1.5rem;
      max-width: 900px;
    }
    .hero-eyebrow {
      font-family: var(--sans); font-size: 0.72rem;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: rgba(245,240,232,0.75);
      margin-bottom: 1.5rem;
      animation: fadeIn 1s ease forwards;
    }
    .hero-title {
      font-family: var(--serif); font-weight: 300;
      font-size: clamp(4rem, 12vw, 10rem);
      line-height: 0.92; letter-spacing: -0.02em;
      color: var(--cream);
      animation: fadeUp 1s ease 0.2s both;
    }
    .hero-sub {
      font-family: var(--sans); font-weight: 300;
      font-size: 1.1rem; color: rgba(245,240,232,0.8);
      margin: 1.75rem auto 2.5rem; max-width: 440px;
      line-height: 1.7;
      animation: fadeUp 1s ease 0.4s both;
    }
    .hero-btns {
      display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
      animation: fadeUp 1s ease 0.6s both;
    }
    .btn-primary {
      font-family: var(--sans); font-size: 0.82rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--cream); color: var(--espresso);
      padding: 1rem 2.5rem; border-radius: 999px;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.3s; display: inline-block;
    }
    .btn-primary:hover { background: var(--amber-light); transform: scale(1.04); }
    .btn-ghost {
      font-family: var(--sans); font-size: 0.82rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      background: rgba(245,240,232,0.15);
      backdrop-filter: blur(6px);
      color: var(--cream);
      padding: 1rem 2.5rem; border-radius: 999px;
      text-decoration: none; border: 1px solid rgba(245,240,232,0.35);
      cursor: pointer; transition: all 0.3s; display: inline-block;
    }
    .btn-ghost:hover { background: rgba(245,240,232,0.25); transform: scale(1.04); }
    .scroll-arrow {
      position: absolute; bottom: 2.5rem; left: 50%;
      transform: translateX(-50%);
      animation: bounce 2s ease infinite;
      color: rgba(245,240,232,0.6);
      text-decoration: none; font-size: 1.4rem;
      z-index: 2;
    }

    /* ─── SECTIONS SHARED ─── */
    section { padding: 7rem 2rem; }
    .container { max-width: 1200px; margin: 0 auto; }
    .section-eye {
      font-family: var(--sans); font-size: 0.7rem;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 1rem;
      display: block;
    }
    .section-title {
      font-family: var(--serif); font-weight: 300;
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      line-height: 1.1; letter-spacing: -0.01em;
      color: var(--text);
    }
    .section-sub {
      font-family: var(--sans); font-size: 1rem;
      color: var(--text-muted); line-height: 1.7;
      max-width: 520px;
    }
    .text-center { text-align: center; }
    .text-center .section-sub { margin: 0 auto; }

    /* ─── ABOUT ─── */
    #about { background: var(--cream); }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 5rem; align-items: center;
    }
    .about-img-wrap {
      position: relative; border-radius: 2rem; overflow: hidden;
      aspect-ratio: 4/5; box-shadow: 0 30px 80px rgba(28,16,8,0.18);
    }
    .about-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .about-text { display: flex; flex-direction: column; gap: 1.5rem; }
    .about-body {
      font-family: var(--sans); font-size: 1rem;
      color: var(--text-muted); line-height: 1.8;
    }
    .about-stats {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1.5rem; padding-top: 2rem;
      border-top: 1px solid var(--border); margin-top: 1rem;
    }
    .stat-num {
      font-family: var(--serif); font-size: 2.6rem; font-weight: 300;
      color: var(--text); line-height: 1;
    }
    .stat-label {
      font-family: var(--sans); font-size: 0.78rem;
      color: var(--text-muted); margin-top: 0.4rem;
      letter-spacing: 0.04em;
    }

    /* ─── FEATURES ─── */
    #features { background: var(--cream-dark); }
    .features-grid {
      display: grid; grid-template-columns: repeat(4,1fr);
      gap: 1.5rem; margin-top: 4rem;
    }
    .feat-card {
      background: var(--card); border-radius: 1.5rem;
      padding: 2.5rem 2rem;
      box-shadow: 0 2px 20px rgba(28,16,8,0.06);
      transition: all 0.4s ease;
    }
    .feat-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 50px rgba(28,16,8,0.12);
    }
    .feat-icon {
      width: 3.2rem; height: 3.2rem; border-radius: 0.9rem;
      background: rgba(200,131,42,0.12);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem; font-size: 1.3rem;
    }
    .feat-title {
      font-family: var(--serif); font-size: 1.25rem; font-weight: 500;
      margin-bottom: 0.75rem;
    }
    .feat-desc {
      font-family: var(--sans); font-size: 0.88rem;
      color: var(--text-muted); line-height: 1.7;
    }

    /* ─── MENU ─── */
    #menu { background: var(--cream); }
    .menu-grid {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 1.5rem; margin-top: 4rem;
    }
    .menu-card {
      background: var(--card); border-radius: 1.5rem;
      padding: 2.5rem;
      box-shadow: 0 2px 20px rgba(28,16,8,0.05);
      transition: box-shadow 0.3s;
    }
    .menu-card:hover { box-shadow: 0 10px 40px rgba(28,16,8,0.1); }
    .menu-cat {
      font-family: var(--serif); font-size: 1.5rem; font-weight: 500;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .menu-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.6rem 0;
    }
    .menu-item-name {
      font-family: var(--sans); font-size: 0.9rem; color: var(--text-muted);
    }
    .menu-item-price {
      font-family: var(--serif); font-size: 1rem; color: var(--brown);
    }
    .menu-more {
      text-align: center; margin-top: 3rem;
    }
    .btn-outline {
      font-family: var(--sans); font-size: 0.82rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      border: 1px solid var(--brown); color: var(--brown);
      background: transparent;
      padding: 1rem 2.5rem; border-radius: 999px;
      cursor: pointer; transition: all 0.3s;
      text-decoration: none; display: inline-block;
    }
    .btn-outline:hover { background: var(--brown); color: var(--cream); }

    /* ─── GALLERY ─── */
    #gallery { background: var(--cream-dark); }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
      gap: 1rem; margin-top: 4rem;
    }
    .gallery-item {
      border-radius: 1.25rem; overflow: hidden;
      cursor: pointer; position: relative;
    }
    .gallery-item img {
      width: 100%; height: 100%; object-fit: cover;
      display: block;
      transition: transform 0.7s ease;
    }
    .gallery-item:hover img { transform: scale(1.07); }
    .gallery-item::after {
      content: ''; position: absolute; inset: 0;
      background: rgba(28,16,8,0);
      transition: background 0.3s;
    }
    .gallery-item:hover::after { background: rgba(28,16,8,0.15); }
    .g1 { aspect-ratio: 1; }
    .g2 { aspect-ratio: 2/3; grid-row: span 2; }
    .g3 { aspect-ratio: 1; }
    .g4 { aspect-ratio: 1; }
    .g5 { aspect-ratio: 1; }
    .g6 { aspect-ratio: 1; }

    /* ─── REVIEWS ─── */
    #reviews { background: var(--cream); }
    .rating-block {
      display: flex; flex-direction: column;
      align-items: center; gap: 0.75rem;
      margin: 2.5rem 0 4rem;
    }
    .stars { display: flex; gap: 0.35rem; }
    .star { color: #f59e0b; font-size: 1.4rem; }
    .rating-num {
      font-family: var(--serif); font-size: 3.5rem; font-weight: 300;
      line-height: 1;
    }
    .rating-count { font-family: var(--sans); font-size: 0.9rem; color: var(--text-muted); }
    .reviews-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .review-card {
      background: var(--card); border-radius: 1.5rem;
      padding: 2.5rem;
      box-shadow: 0 2px 20px rgba(28,16,8,0.05);
      transition: all 0.4s;
    }
    .review-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 40px rgba(28,16,8,0.1);
    }
    .quote-icon {
      font-family: var(--serif); font-size: 4rem; font-weight: 300;
      color: var(--amber); line-height: 0.5; margin-bottom: 1.5rem;
      display: block;
    }
    .review-text {
      font-family: var(--sans); font-size: 1rem;
      color: var(--text-muted); line-height: 1.75;
      margin-bottom: 1.75rem;
    }
    .review-footer { display: flex; align-items: center; justify-content: space-between; }
    .review-name { font-family: var(--serif); font-size: 1.1rem; font-weight: 500; }
    .review-stars { display: flex; gap: 2px; }
    .review-stars span { color: #f59e0b; font-size: 0.85rem; }

    /* ─── VISIT ─── */
    #visit { background: var(--espresso-mid); }
    #visit .section-eye { color: var(--amber-light); }
    #visit .section-title { color: var(--cream); }
    .visit-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: center; margin-top: 3rem;
    }
    .map-wrap {
      border-radius: 2rem; overflow: hidden;
      height: 480px;
      box-shadow: 0 40px 80px rgba(0,0,0,0.3);
    }
    .map-wrap iframe { width: 100%; height: 100%; border: 0; }
    .visit-info { display: flex; flex-direction: column; gap: 2.5rem; }
    .visit-row { display: flex; align-items: flex-start; gap: 1.25rem; }
    .visit-icon-wrap {
      width: 3rem; height: 3rem; border-radius: 0.9rem;
      background: rgba(200,131,42,0.2);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 1.1rem;
    }
    .visit-row-title {
      font-family: var(--serif); font-size: 1.15rem; font-weight: 500;
      color: var(--cream); margin-bottom: 0.4rem;
    }
    .visit-row-text {
      font-family: var(--sans); font-size: 0.9rem;
      color: rgba(245,240,232,0.65); line-height: 1.7;
    }
    .services-row { display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .service-pill {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.45rem 1.1rem; border-radius: 999px;
      font-family: var(--sans); font-size: 0.8rem;
    }
    .service-pill.yes { background: rgba(200,131,42,0.2); color: var(--amber-light); }
    .service-pill.no { background: rgba(245,240,232,0.08); color: rgba(245,240,232,0.4); }
    .btn-primary-dark {
      font-family: var(--sans); font-size: 0.82rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--amber); color: var(--espresso);
      padding: 1rem 2.5rem; border-radius: 999px;
      text-decoration: none; border: none; cursor: pointer;
      transition: all 0.3s; display: inline-block; font-weight: 500;
    }
    .btn-primary-dark:hover { background: var(--amber-light); transform: scale(1.04); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--espresso); color: var(--cream);
      padding: 5rem 2rem 3rem;
    }
    .footer-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 4rem; margin-bottom: 4rem;
    }
    .footer-brand-name {
      font-family: var(--serif); font-size: 2rem; font-weight: 300;
      margin-bottom: 1rem;
    }
    .footer-brand-text {
      font-family: var(--sans); font-size: 0.88rem;
      color: rgba(245,240,232,0.55); line-height: 1.7;
    }
    .footer-heading {
      font-family: var(--serif); font-size: 1.1rem; font-weight: 500;
      margin-bottom: 1.25rem;
    }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .footer-links a {
      font-family: var(--sans); font-size: 0.88rem;
      color: rgba(245,240,232,0.55); text-decoration: none;
      transition: color 0.3s;
    }
    .footer-links a:hover { color: var(--cream); }
    .footer-address {
      font-family: var(--sans); font-size: 0.88rem;
      color: rgba(245,240,232,0.55); font-style: normal;
      line-height: 1.7; margin-bottom: 1.5rem;
    }
    .socials { display: flex; gap: 0.75rem; }
    .social-btn {
      width: 2.5rem; height: 2.5rem; border-radius: 999px;
      background: rgba(245,240,232,0.1);
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; color: var(--cream);
      font-size: 0.9rem;
      transition: background 0.3s;
    }
    .social-btn:hover { background: rgba(245,240,232,0.2); }
    .footer-bottom {
      max-width: 1200px; margin: 0 auto;
      padding-top: 2rem; border-top: 1px solid rgba(245,240,232,0.12);
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; flex-wrap: wrap;
    }
    .footer-copy {
      font-family: var(--sans); font-size: 0.8rem;
      color: rgba(245,240,232,0.35);
    }
    .footer-legal { display: flex; gap: 1.5rem; }
    .footer-legal a {
      font-family: var(--sans); font-size: 0.8rem;
      color: rgba(245,240,232,0.35); text-decoration: none;
      transition: color 0.3s;
    }
    .footer-legal a:hover { color: rgba(245,240,232,0.7); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes bounce {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(8px); }
    }
    .reveal {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-left {
      opacity: 0; transform: translateX(-30px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .reveal-left.visible { opacity: 1; transform: translateX(0); }
    .reveal-right {
      opacity: 0; transform: translateX(30px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .reveal-right.visible { opacity: 1; transform: translateX(0); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .about-grid, .visit-grid { grid-template-columns: 1fr; }
      .about-img-wrap { max-height: 380px; }
      .features-grid { grid-template-columns: 1fr 1fr; }
      .menu-grid { grid-template-columns: 1fr 1fr; }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      section { padding: 5rem 1.25rem; }
      .features-grid, .menu-grid { grid-template-columns: 1fr; }
      .about-stats { grid-template-columns: repeat(3,1fr); }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .g2 { grid-row: span 1; aspect-ratio: 1; }
      .footer-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<!-- ─── NAV ─── -->
<header id="header">
  <div class="nav-inner">
    <a href="#" class="logo">Velvet Crema</a>
    <nav class="nav-links">
      <a href="#about">About</a>
      <a href="#menu">Menu</a>
      <a href="#gallery">Gallery</a>
      <a href="#reviews">Reviews</a>
      <a href="#visit">Visit</a>
      <a href="#visit" class="nav-btn">Visit Us</a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-nav" id="mobileNav">
    <a href="#about" onclick="closeMobile()">About</a>
    <a href="#menu" onclick="closeMobile()">Menu</a>
    <a href="#gallery" onclick="closeMobile()">Gallery</a>
    <a href="#reviews" onclick="closeMobile()">Reviews</a>
    <a href="#visit" onclick="closeMobile()">Visit Us</a>
  </div>
</header>

<!-- ─── HERO ─── -->
<section id="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content" id="heroContent">
    <p class="hero-eyebrow">Toronto's Cozy Coffee Spot</p>
    <h1 class="hero-title">Velvet<br>Crema</h1>
    <p class="hero-sub">A cozy Toronto coffee spot for coffee, calm, and good taste</p>
    <div class="hero-btns">
